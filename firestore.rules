rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email']) &&
               data.uid is string && data.uid.size() <= 128 &&
               data.email is string && data.email.size() <= 256;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        // Allow updating health profile fields
        incoming().diff(existing()).affectedKeys().hasOnly(['healthProfile', 'updatedAt']) ||
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt'])
      );
    }

    // --- Sessions Collection ---
    match /sessions/{sessionId} {
      function isValidSession(data) {
        return data.keys().hasAll(['id', 'userId', 'title', 'timestamp']) &&
               data.id is string && data.id.size() <= 128 &&
               data.userId == request.auth.uid &&
               data.title is string && data.title.size() <= 256 &&
               data.timestamp is int;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidSession(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt'])
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      // --- Messages Subcollection ---
      match /messages/{messageId} {
        function isValidMessage(data) {
          return data.keys().hasAll(['id', 'sessionId', 'isUser', 'timestamp']) &&
                 data.id is string && data.id.size() <= 128 &&
                 data.sessionId == sessionId &&
                 data.isUser is bool &&
                 data.timestamp is int;
        }

        // We check the parent session for ownership
        function canAccessSession() {
          return get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
        }

        allow list: if isSignedIn() && canAccessSession();
        allow get: if isSignedIn() && canAccessSession();
        allow create: if isSignedIn() && canAccessSession() && isValidMessage(incoming());
        allow update: if isSignedIn() && canAccessSession() && (
          // Allow appending chunks to text during live transcription
          incoming().diff(existing()).affectedKeys().hasOnly(['text', 'timestamp'])
        );
      }
    }
  }
}
